{
  "productName": "Baudbound",
  "bundle": {
    "targets": ["appimage", "deb", "rpm"],
    "linux": {
      "deb": {
        "desktopTemplate": "linux/baudbound.desktop.hbs",
        "depends": [
          "libasound2",
          "libudev1"
        ],
        "priority": "optional",
        "section": "utils"
      },
      "rpm": {
        "desktopTemplate": "linux/baudbound.desktop.hbs",
        "depends": [
          "libasound.so.2()(64bit)",
          "libudev.so.1()(64bit)"
        ],
        "epoch": 0,
        "release": "1"
      }
    }
  }
}
