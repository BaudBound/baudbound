{
	"name": "baudbound-editor",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --webpack",
		"dev:turbo": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"e2e": "playwright test",
		"schemas:check": "node scripts/generate-node-schemas.mjs --check",
		"schemas:generate": "node scripts/generate-node-schemas.mjs",
		"test": "node --test tests/*.test.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "biome check",
		"verify:release": "pnpm lint && pnpm typecheck && pnpm schemas:check && pnpm test && pnpm build && pnpm e2e",
		"format": "biome format --write"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@xyflow/react": "^12.11.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"jszip": "^3.10.1",
		"lucide-react": "^1.23.0",
		"next": "16.2.9",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.6.1",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"shadcn": "^4.12.0",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5"
	}
}
