{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/program.schema.json",
	"title": "BaudBound Program",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"entry"
	],
	"properties": {
		"entry": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"trigger",
				"triggers",
				"program"
			],
			"properties": {
				"trigger": {
					"$ref": "#/$defs/trigger"
				},
				"triggers": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/trigger"
					}
				},
				"program": {
					"$ref": "#/$defs/block"
				}
			}
		}
	},
	"$defs": {
		"actionType": {
			"type": "string",
			"enum": [
				"action.application.open",
				"action.beep",
				"action.calculate",
				"action.clipboard.get",
				"action.clipboard.set",
				"action.delay",
				"action.file.copy",
				"action.file.delete",
				"action.file.download",
				"action.file.move",
				"action.file.read",
				"action.file.write",
				"action.http",
				"action.keyboard",
				"action.keyboard.type_text",
				"action.log",
				"action.message_box",
				"action.mouse",
				"action.mouse.move",
				"action.notification",
				"action.pixel.get",
				"action.process.kill",
				"action.process.run",
				"action.process.status",
				"action.script.run",
				"action.serial.write",
				"action.shell",
				"action.sound.play",
				"action.text.format",
				"action.webhook_response",
				"action.websocket.write",
				"action.window.active",
				"action.window.focus",
				"control.color_match",
				"control.for_each",
				"control.if",
				"control.loop",
				"control.switch",
				"control.while",
				"runtime.set_variable",
				"trigger.file_watch",
				"trigger.hotkey",
				"trigger.manual",
				"trigger.process_started",
				"trigger.schedule",
				"trigger.serial_input",
				"trigger.startup",
				"trigger.webhook",
				"trigger.websocket"
			]
		},
		"triggerActionType": {
			"type": "string",
			"enum": [
				"trigger.file_watch",
				"trigger.hotkey",
				"trigger.manual",
				"trigger.process_started",
				"trigger.schedule",
				"trigger.serial_input",
				"trigger.startup",
				"trigger.webhook",
				"trigger.websocket"
			]
		},
		"controlActionType": {
			"type": "string",
			"enum": [
				"control.color_match",
				"control.for_each",
				"control.if",
				"control.loop",
				"control.switch",
				"control.while"
			]
		},
		"executableActionType": {
			"type": "string",
			"enum": [
				"action.application.open",
				"action.beep",
				"action.calculate",
				"action.clipboard.get",
				"action.clipboard.set",
				"action.delay",
				"action.file.copy",
				"action.file.delete",
				"action.file.download",
				"action.file.move",
				"action.file.read",
				"action.file.write",
				"action.http",
				"action.keyboard",
				"action.keyboard.type_text",
				"action.log",
				"action.message_box",
				"action.mouse",
				"action.mouse.move",
				"action.notification",
				"action.pixel.get",
				"action.process.kill",
				"action.process.run",
				"action.process.status",
				"action.script.run",
				"action.serial.write",
				"action.shell",
				"action.sound.play",
				"action.text.format",
				"action.webhook_response",
				"action.websocket.write",
				"action.window.active",
				"action.window.focus"
			]
		},
		"triggerType": {
			"type": "string",
			"enum": [
				"file_watch",
				"hotkey",
				"manual",
				"process_started",
				"schedule",
				"serial_input",
				"startup",
				"webhook",
				"websocket"
			]
		},
		"actionRunnerType": {
			"type": "string",
			"enum": [
				"open_application",
				"beep",
				"calculate",
				"get_clipboard",
				"set_clipboard",
				"delay",
				"copy_file",
				"delete_file",
				"download_file",
				"move_file",
				"read_file",
				"write_file",
				"http_request",
				"press_key",
				"type_text",
				"log",
				"show_message_box",
				"mouse_click",
				"move_mouse",
				"show_notification",
				"get_pixel_color",
				"kill_process",
				"run_process",
				"process_status",
				"run_sub_script",
				"serial_write",
				"run_shell_command",
				"play_sound",
				"format_text",
				"webhook_response",
				"websocket_write",
				"get_active_window",
				"focus_window"
			]
		},
		"controlStepType": {
			"type": "string",
			"enum": [
				"color_match",
				"for_each",
				"if",
				"loop",
				"switch",
				"while"
			]
		},
		"runtimeDataType": {
			"type": "string",
			"enum": [
				"string",
				"number",
				"boolean",
				"object",
				"list",
				"file_content",
				"file_path",
				"http_headers",
				"http_status_code",
				"duration_ms",
				"process_id",
				"exit_code",
				"keyboard_key"
			]
		},
		"variableType": {
			"type": "string",
			"enum": [
				"string",
				"number",
				"boolean",
				"object",
				"list",
				"file_content",
				"http_response",
				"datetime",
				"duration",
				"file_path",
				"http_headers",
				"http_status_code",
				"duration_ms",
				"process_id",
				"exit_code",
				"keyboard_key"
			]
		},
		"jsonValue": {
			"anyOf": [
				{
					"type": "string"
				},
				{
					"type": "number"
				},
				{
					"type": "boolean"
				},
				{
					"type": "null"
				},
				{
					"type": "array",
					"items": {
						"$ref": "#/$defs/jsonValue"
					}
				},
				{
					"type": "object",
					"additionalProperties": {
						"$ref": "#/$defs/jsonValue"
					}
				}
			]
		},
		"config": {
			"type": "object",
			"propertyNames": {
				"enum": [
					"amount",
					"application",
					"arguments",
					"assetPath",
					"autoReconnect",
					"baudRate",
					"body",
					"button",
					"buttons",
					"cases",
					"clickType",
					"command",
					"conditions",
					"connectionId",
					"content",
					"contentType",
					"count",
					"customName",
					"data",
					"dataBits",
					"destinationPath",
					"deviceId",
					"delimiter",
					"durationMs",
					"encoding",
					"every",
					"executable",
					"expression",
					"fieldPath",
					"filePath",
					"flowControl",
					"frequencyHz",
					"headers",
					"hookName",
					"indexVariable",
					"input",
					"itemVariable",
					"items",
					"key",
					"label",
					"level",
					"length",
					"lineEnding",
					"matchMode",
					"message",
					"method",
					"mode",
					"name",
					"operation",
					"overwrite",
					"parity",
					"path",
					"pad",
					"port",
					"productId",
					"readMode",
					"relative",
					"replacement",
					"responseTimeoutSeconds",
					"scope",
					"search",
					"script",
					"source",
					"sourcePath",
					"start",
					"statusCode",
					"stopBits",
					"target",
					"targetLength",
					"template",
					"text",
					"timeoutSeconds",
					"timeoutResponseBody",
					"timeoutResponseContentType",
					"timeoutResponseStatus",
					"title",
					"type",
					"unit",
					"url",
					"userAgent",
					"value",
					"valueType",
					"validateUsbIdentity",
					"vendorId",
					"waitForResponse",
					"workingDirectory",
					"x",
					"y"
				]
			},
			"additionalProperties": {
				"$ref": "#/$defs/jsonValue"
			}
		},
		"runtimeOutputField": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"name",
				"type",
				"description"
			],
			"properties": {
				"name": {
					"type": "string",
					"minLength": 1
				},
				"type": {
					"$ref": "#/$defs/runtimeDataType"
				},
				"description": {
					"type": "string"
				},
				"example": {
					"type": "string"
				}
			}
		},
		"runtimeOutput": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"name",
				"type",
				"description"
			],
			"properties": {
				"name": {
					"type": "string",
					"minLength": 1
				},
				"type": {
					"$ref": "#/$defs/runtimeDataType"
				},
				"description": {
					"type": "string"
				},
				"example": {
					"type": "string"
				},
				"fields": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/runtimeOutputField"
					}
				}
			}
		},
		"variable": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"name",
				"token",
				"type",
				"scope",
				"source",
				"read_only"
			],
			"properties": {
				"name": {
					"type": "string",
					"minLength": 1
				},
				"token": {
					"type": "string",
					"pattern": "^\\{\\{[^{}]+\\}\\}$"
				},
				"type": {
					"$ref": "#/$defs/variableType"
				},
				"scope": {
					"type": "string",
					"enum": [
						"runtime",
						"persistent",
						"global",
						"manifest",
						"system",
						"node_output"
					]
				},
				"source": {
					"type": "string",
					"enum": [
						"user",
						"built_in",
						"node_output"
					]
				},
				"read_only": {
					"type": "boolean"
				},
				"description": {
					"type": "string"
				},
				"binding": {
					"type": "string",
					"minLength": 1
				},
				"value": {
					"$ref": "#/$defs/jsonValue"
				}
			}
		},
		"builtInVariableContext": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"syntax",
				"variables"
			],
			"properties": {
				"syntax": {
					"const": "{{variable_name}}"
				},
				"variables": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/variable"
					}
				}
			}
		},
		"nodeOutputReference": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"action_type",
				"outputs"
			],
			"properties": {
				"id": {
					"type": "string",
					"minLength": 1
				},
				"action_type": {
					"$ref": "#/$defs/actionType"
				},
				"outputs": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/runtimeOutput"
					}
				}
			}
		},
		"runtimeContext": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"expression_reference",
				"template_reference",
				"variables",
				"built_in_variables",
				"node_outputs"
			],
			"properties": {
				"expression_reference": {
					"const": "{{node-id.data_name}}"
				},
				"template_reference": {
					"const": "{{node-id.data_name}}"
				},
				"variables": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/variable"
					}
				},
				"built_in_variables": {
					"$ref": "#/$defs/builtInVariableContext"
				},
				"node_outputs": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/nodeOutputReference"
					}
				}
			}
		},
		"trigger": {
			"oneOf": [
				{
					"$ref": "https://schemas.baudbound.app/nodes/trigger-file-watch.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/trigger-hotkey.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/trigger-manual.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/trigger-process-started.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/trigger-schedule.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/trigger-serial-input.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/trigger-startup.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/trigger-webhook.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/trigger-websocket.schema.json"
				}
			]
		},
		"controlStep": {
			"oneOf": [
				{
					"$ref": "https://schemas.baudbound.app/nodes/control-color-match.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/control-for-each.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/control-if.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/control-loop.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/control-switch.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/control-while.schema.json"
				}
			]
		},
		"variableOperationStep": {
			"oneOf": [
				{
					"$ref": "https://schemas.baudbound.app/nodes/runtime-set-variable.schema.json"
				}
			]
		},
		"actionStep": {
			"oneOf": [
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-application-open.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-beep.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-calculate.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-clipboard-get.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-clipboard-set.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-delay.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-file-copy.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-file-delete.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-file-download.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-file-move.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-file-read.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-file-write.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-http.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-keyboard.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-keyboard-type-text.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-log.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-message-box.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-mouse.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-mouse-move.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-notification.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-pixel-get.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-process-kill.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-process-run.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-process-status.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-script-run.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-serial-write.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-shell.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-sound-play.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-text-format.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-webhook-response.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-websocket-write.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-window-active.schema.json"
				},
				{
					"$ref": "https://schemas.baudbound.app/nodes/action-window-focus.schema.json"
				}
			]
		},
		"step": {
			"oneOf": [
				{
					"$ref": "#/$defs/controlStep"
				},
				{
					"$ref": "#/$defs/variableOperationStep"
				},
				{
					"$ref": "#/$defs/actionStep"
				}
			]
		},
		"edge": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"execution_order",
				"source",
				"source_handle",
				"target",
				"target_handle"
			],
			"properties": {
				"execution_order": {
					"type": "integer",
					"minimum": 0,
					"maximum": 4294967295
				},
				"source": {
					"type": "string",
					"minLength": 1
				},
				"source_handle": {
					"type": "string",
					"minLength": 1
				},
				"target": {
					"type": "string",
					"minLength": 1
				},
				"target_handle": {
					"type": "string",
					"minLength": 1
				}
			}
		},
		"block": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"type",
				"execution_model",
				"runtime_context",
				"steps",
				"edges"
			],
			"properties": {
				"type": {
					"const": "block"
				},
				"execution_model": {
					"const": "directed_graph"
				},
				"runtime_context": {
					"$ref": "#/$defs/runtimeContext"
				},
				"steps": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/step"
					}
				},
				"edges": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/edge"
					}
				}
			}
		}
	}
}
