{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.baudbound.app/manifest.schema.json",
  "title": "BaudBound Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "script_language_version",
    "id",
    "name",
    "created_with",
    "created_at",
    "minimum_runner_version"
  ],
  "properties": {
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "script_language_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "format": "uuid",
      "maxLength": 36
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "maxLength": 4096
    },
    "author": {
      "type": "string",
      "maxLength": 128
    },
    "website": {
      "type": "string",
      "maxLength": 2048
    },
    "source": {
      "type": "string",
      "maxLength": 2048
    },
    "created_with": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64
    },
    "tags": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "uniqueItems": true
    },
    "minimum_runner_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
      "maxLength": 128
    },
    "update_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://",
      "maxLength": 2048
    },
    "assets": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "media_type", "name", "path", "size"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "kind": {
            "enum": ["audio", "image", "text"]
          },
          "media_type": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "path": {
            "type": "string",
            "pattern": "^assets(?:\\/[a-z0-9._-]+)+$",
            "maxLength": 256
          },
          "size": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "uniqueItems": true
    },
    "variables": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "scope", "type", "value"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
            "maxLength": 128
          },
          "scope": {
            "type": "string",
            "enum": ["runtime", "persistent"]
          },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "object", "list", "http_response", "datetime", "duration", "file_path"]
          },
          "description": {
            "type": "string",
            "maxLength": 1024
          },
          "value": {
            "type": ["string", "number", "boolean", "object", "array", "null"]
          }
        },
        "oneOf": [
          {
            "properties": { "type": { "const": "string" }, "value": { "type": "string", "pattern": "\\S" } }
          },
          {
            "properties": { "type": { "const": "file_path" }, "value": { "type": "string", "pattern": "\\S" } }
          },
          {
            "properties": { "type": { "const": "number" }, "value": { "type": "number" } }
          },
          {
            "properties": { "type": { "const": "boolean" }, "value": { "type": "boolean" } }
          },
          {
            "properties": { "type": { "const": "list" }, "value": { "type": "array" } }
          },
          {
            "properties": { "type": { "const": "object" }, "value": { "type": "object" } }
          },
          {
            "properties": {
              "type": { "const": "http_response" },
              "value": {
                "type": "object",
                "required": ["type", "status", "headers", "body"],
                "properties": {
                  "type": { "const": "http_response" },
                  "status": { "type": "number" },
                  "headers": { "type": "object" }
                }
              }
            }
          },
          {
            "properties": {
              "type": { "const": "datetime" },
              "value": {
                "type": "object",
                "required": ["type", "value"],
                "properties": {
                  "type": { "const": "datetime" },
                  "value": { "type": "string" }
                }
              }
            }
          },
          {
            "properties": {
              "type": { "const": "duration" },
              "value": {
                "type": "object",
                "required": ["type", "value", "unit"],
                "properties": {
                  "type": { "const": "duration" },
                  "value": { "type": "number" },
                  "unit": { "type": "string" }
                }
              }
            }
          }
        ]
      },
      "uniqueItems": true
    },
    "secrets": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type", "required"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
            "maxLength": 128
          },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "object", "list", "http_response", "datetime", "duration", "file_path"]
          },
          "description": {
            "type": "string",
            "maxLength": 1024
          },
          "required": {
            "type": "boolean"
          }
        }
      },
      "uniqueItems": true
    }
  }
}
