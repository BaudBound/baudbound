{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.baudbound.app/manifest.schema.json",
  "title": "BaudBound Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "script_language_version",
    "id",
    "name",
    "created_with",
    "created_at",
    "minimum_runner_version"
  ],
  "properties": {
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "script_language_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "string",
      "format": "uri"
    },
    "created_with": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "minimum_runner_version": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "media_type", "name", "path", "size"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": ["audio", "image", "text"]
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "pattern": "^assets\\/[a-z0-9._-]+$"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "uniqueItems": true
    },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "scope", "type", "value"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "scope": {
            "type": "string",
            "enum": ["runtime", "persistent"]
          },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "object", "list", "http_response", "datetime", "duration", "file_path"]
          },
          "description": {
            "type": "string"
          },
          "value": {
            "type": ["string", "number", "boolean", "object", "array", "null"]
          }
        },
        "oneOf": [
          {
            "properties": { "type": { "const": "string" }, "value": { "type": "string", "pattern": "\\S" } }
          },
          {
            "properties": { "type": { "const": "file_path" }, "value": { "type": "string", "pattern": "\\S" } }
          },
          {
            "properties": { "type": { "const": "number" }, "value": { "type": "number" } }
          },
          {
            "properties": { "type": { "const": "boolean" }, "value": { "type": "boolean" } }
          },
          {
            "properties": { "type": { "const": "list" }, "value": { "type": "array" } }
          },
          {
            "properties": { "type": { "const": "object" }, "value": { "type": "object" } }
          },
          {
            "properties": {
              "type": { "const": "http_response" },
              "value": {
                "type": "object",
                "required": ["type", "status", "headers", "body"],
                "properties": {
                  "type": { "const": "http_response" },
                  "status": { "type": "number" },
                  "headers": { "type": "object" }
                }
              }
            }
          },
          {
            "properties": {
              "type": { "const": "datetime" },
              "value": {
                "type": "object",
                "required": ["type", "value"],
                "properties": {
                  "type": { "const": "datetime" },
                  "value": { "type": "string" }
                }
              }
            }
          },
          {
            "properties": {
              "type": { "const": "duration" },
              "value": {
                "type": "object",
                "required": ["type", "value", "unit"],
                "properties": {
                  "type": { "const": "duration" },
                  "value": { "type": "number" },
                  "unit": { "type": "string" }
                }
              }
            }
          }
        ]
      },
      "uniqueItems": true
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type", "required"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "object", "list", "http_response", "datetime", "duration", "file_path"]
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        }
      },
      "uniqueItems": true
    }
  }
}
