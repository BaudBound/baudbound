{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.baudbound.app/manifest.schema.json",
  "title": "BaudBound Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "script_language_version",
    "id",
    "name",
    "created_with",
    "created_at",
    "minimum_runner_version"
  ],
  "properties": {
    "format_version": {
      "type": "integer",
      "minimum": 1
    },
    "script_language_version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "string",
      "format": "uri"
    },
    "created_with": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "minimum_runner_version": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "media_type", "name", "path", "size"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": ["audio", "image", "text"]
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "pattern": "^assets\\/[a-z0-9._-]+$"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "uniqueItems": true
    }
  }
}
