{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/capabilities.schema.json",
	"title": "BaudBound Capabilities",
	"type": "object",
	"additionalProperties": false,
	"required": ["required_capabilities", "target_runtime"],
	"properties": {
		"required_capabilities": {
			"type": "array",
			"items": {
				"type": "string",
				"enum": [
					"trigger.manual",
					"trigger.schedule",
					"trigger.hotkey",
					"trigger.file_watch",
					"trigger.webhook",
					"trigger.websocket",
					"trigger.serial_input",
					"trigger.startup",
					"trigger.process_started",
					"action.log",
					"action.delay",
					"action.notification",
					"action.message_box",
					"action.http",
					"action.webhook_response",
					"action.websocket",
					"action.file",
					"action.process",
					"action.keyboard",
					"action.mouse",
					"action.clipboard",
					"action.window",
					"action.sound",
					"action.text",
					"action.calculate",
					"action.pixel",
					"action.serial",
					"action.sub_script",
					"runtime.variables",
					"runtime.color_match",
					"runtime.if",
					"runtime.switch",
					"runtime.loop",
					"runtime.while",
					"runtime.for_each",
					"runtime.sub_script",
					"runtime.error_handling",
					"runtime.persistent_storage",
					"runtime.secrets"
				]
			},
			"uniqueItems": true
		},
		"target_runtime": {
			"type": "string",
			"enum": [
				"Generic Headless",
				"Linux Headless",
				"Windows Headless",
				"Generic Desktop",
				"Windows Desktop",
				"Linux Desktop"
			]
		}
	}
}
