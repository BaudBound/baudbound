{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/action-mouse-move.schema.json",
	"title": "BaudBound Node - Move Mouse",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"action",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "action.mouse.move"
		},
		"type": {
			"const": "action"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		},
		"action": {
			"const": "move_mouse"
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"relative",
				"x",
				"y"
			],
			"properties": {
				"customName": {
					"type": "string"
				},
				"relative": {
					"type": "boolean"
				},
				"x": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"type": "string",
							"minLength": 1
						}
					]
				},
				"y": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"type": "string",
							"minLength": 1
						}
					]
				}
			}
		}
	}
}
