{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/trigger-webhook.schema.json",
	"title": "BaudBound Node - Webhook",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "trigger.webhook"
		},
		"type": {
			"const": "webhook"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"hookName",
				"method"
			],
			"properties": {
				"customName": {
					"type": "string"
				},
				"hookName": {
					"type": "string"
				},
				"method": {
					"type": "string",
					"enum": [
						"GET",
						"POST",
						"PUT",
						"PATCH",
						"DELETE",
						"HEAD",
						"OPTIONS"
					]
				},
				"responseTimeoutSeconds": {
					"anyOf": [
						{
							"type": "number",
							"exclusiveMinimum": 0,
							"maximum": 86400
						},
						{
							"type": "string",
							"pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?$"
						}
					]
				},
				"timeoutResponseBody": {
					"type": "string"
				},
				"timeoutResponseContentType": {
					"type": "string"
				},
				"timeoutResponseStatus": {
					"anyOf": [
						{
							"type": "integer",
							"minimum": 100,
							"maximum": 599
						},
						{
							"type": "string",
							"pattern": "^(?:0|[1-9][0-9]*)$"
						}
					]
				},
				"waitForResponse": {
					"type": "boolean"
				}
			}
		}
	}
}
