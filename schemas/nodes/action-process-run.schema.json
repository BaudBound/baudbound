{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/action-process-run.schema.json",
	"title": "BaudBound Node - Run Process",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"action",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "action.process.run"
		},
		"type": {
			"const": "action"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		},
		"action": {
			"const": "run_process"
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"arguments",
				"executable",
				"workingDirectory"
			],
			"properties": {
				"arguments": {
					"type": "string"
				},
				"customName": {
					"type": "string"
				},
				"executable": {
					"type": "string"
				},
				"timeoutSeconds": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"type": "string",
							"minLength": 1
						}
					]
				},
				"workingDirectory": {
					"type": "string"
				}
			}
		}
	}
}
