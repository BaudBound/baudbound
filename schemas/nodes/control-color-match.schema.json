{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/control-color-match.schema.json",
	"title": "BaudBound Node - Color Match",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "control.color_match"
		},
		"type": {
			"const": "color_match"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"actualColor",
				"comparisonMode",
				"expectedColor",
				"tolerancePercent"
			],
			"properties": {
				"actualColor": {
					"type": "string"
				},
				"comparisonMode": {
					"type": "string",
					"enum": [
						"per_channel",
						"total_distance"
					]
				},
				"customName": {
					"type": "string"
				},
				"expectedColor": {
					"type": "string"
				},
				"tolerancePercent": {
					"anyOf": [
						{
							"type": "number",
							"minimum": 0,
							"maximum": 100
						},
						{
							"type": "string",
							"minLength": 1
						}
					]
				}
			}
		}
	}
}
