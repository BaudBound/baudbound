{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/control-if.schema.json",
	"title": "BaudBound Node - If / Else",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "control.if"
		},
		"type": {
			"const": "if"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"conditions": {
					"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/jsonValue"
				},
				"customName": {
					"type": "string"
				}
			}
		}
	}
}
