{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/action-shell.schema.json",
	"title": "BaudBound Node - Shell Command",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"action",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "action.shell"
		},
		"type": {
			"const": "action"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		},
		"action": {
			"const": "run_shell_command"
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"command"
			],
			"properties": {
				"command": {
					"type": "string"
				},
				"customName": {
					"type": "string"
				},
				"timeoutSeconds": {
					"anyOf": [
						{
							"type": "number",
							"minimum": 1,
							"maximum": 86400
						},
						{
							"type": "string",
							"minLength": 1
						}
					]
				}
			}
		}
	}
}
