{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/action-process-kill.schema.json",
	"title": "BaudBound Node - Kill Process",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"action",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "action.process.kill"
		},
		"type": {
			"const": "action"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		},
		"action": {
			"const": "kill_process"
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"matchMode",
				"target"
			],
			"properties": {
				"customName": {
					"type": "string"
				},
				"matchMode": {
					"type": "string",
					"enum": [
						"process_name",
						"executable_path",
						"window_title",
						"pid"
					]
				},
				"target": {
					"type": "string"
				}
			}
		}
	}
}
