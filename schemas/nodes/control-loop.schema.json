{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/control-loop.schema.json",
	"title": "BaudBound Node - Loop",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "control.loop"
		},
		"type": {
			"const": "loop"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"count"
			],
			"properties": {
				"count": {
					"anyOf": [
						{
							"type": "number"
						},
						{
							"type": "string",
							"minLength": 1
						}
					]
				},
				"customName": {
					"type": "string"
				}
			}
		}
	}
}
