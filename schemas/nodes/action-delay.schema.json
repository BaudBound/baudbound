{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/action-delay.schema.json",
	"title": "BaudBound Node - Delay",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"action",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "action.delay"
		},
		"type": {
			"const": "action"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		},
		"action": {
			"const": "delay"
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"amount",
				"unit"
			],
			"properties": {
				"amount": {
					"anyOf": [
						{
							"type": "number",
							"exclusiveMinimum": 0,
							"maximum": 1.7976931348623157e+308
						},
						{
							"type": "string",
							"minLength": 1
						}
					]
				},
				"customName": {
					"type": "string"
				},
				"unit": {
					"type": "string",
					"enum": [
						"milliseconds",
						"seconds",
						"minutes",
						"hours",
						"days"
					]
				}
			}
		}
	}
}
