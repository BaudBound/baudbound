{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/action-webhook-response.schema.json",
	"title": "BaudBound Node - Webhook Response",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"action",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "action.webhook_response"
		},
		"type": {
			"const": "action"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		},
		"action": {
			"const": "webhook_response"
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"body",
				"contentType",
				"statusCode"
			],
			"properties": {
				"body": {
					"type": "string"
				},
				"contentType": {
					"type": "string"
				},
				"customName": {
					"type": "string"
				},
				"headers": {
					"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/jsonValue"
				},
				"statusCode": {
					"anyOf": [
						{
							"type": "integer",
							"minimum": 100,
							"maximum": 599
						},
						{
							"type": "string",
							"minLength": 1
						}
					]
				}
			}
		}
	}
}
