{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://schemas.baudbound.app/nodes/action-beep.schema.json",
	"title": "BaudBound Node - Beep",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"action_type",
		"type",
		"action",
		"config",
		"runtime_outputs"
	],
	"properties": {
		"id": {
			"type": "string",
			"minLength": 1
		},
		"action_type": {
			"const": "action.beep"
		},
		"type": {
			"const": "action"
		},
		"config": {
			"$ref": "#/$defs/config"
		},
		"runtime_outputs": {
			"type": "array",
			"items": {
				"$ref": "https://schemas.baudbound.app/program.schema.json#/$defs/runtimeOutput"
			}
		},
		"action": {
			"const": "beep"
		}
	},
	"$defs": {
		"config": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"durationMs",
				"frequencyHz"
			],
			"properties": {
				"customName": {
					"type": "string"
				},
				"durationMs": {
					"anyOf": [
						{
							"type": "number",
							"minimum": 10,
							"maximum": 5000
						},
						{
							"type": "string",
							"minLength": 1
						}
					]
				},
				"frequencyHz": {
					"anyOf": [
						{
							"type": "number",
							"minimum": 20,
							"maximum": 20000
						},
						{
							"type": "string",
							"minLength": 1
						}
					]
				}
			}
		}
	}
}
